# Colony configuration for {{PROJECT_NAME}}
# Rename to colony.config.yaml and fill in values before running `colony start`

github:
  owner: {{GITHUB_OWNER}}
  repo: {{GITHUB_REPO}}
  # token_env: GITHUB_TOKEN  # or use GitHub App auth

workspace:
  repo_dir: /tmp/colony/repos
  base_dir: /tmp/colony/workspaces
  setup_command: "npm install"

review:
  checks:
    typecheck: "npm run typecheck"
    lint: "npm run lint"
    test: "npm test"

agents:
  sprint_master:
    poll_interval: 30
    health_port: 3001
  analyzer:
    poll_interval: 30
    health_port: 3002
  developer:
    poll_interval: 60
    health_port: 3003
  reviewer:
    poll_interval: 30
    health_port: 3004
  merger:
    poll_interval: 30
    health_port: 3005
